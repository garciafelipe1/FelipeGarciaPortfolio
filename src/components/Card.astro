---
interface Props {
  title: string
  description: string
  href: string
  icon: string
  stack: { name: string; icon: string }[]
  image?: string
  tags?: string[]
  meta?: string
  repo?: string
  locale?: string
  caseStudySlug?: string
}

const { href, title, description, stack, icon, image, tags, meta, repo, locale, caseStudySlug } =
  Astro.props

const isGithub = (url?: string) => (url ? url.includes('github.com') : false)
const liveHref = href
const codeHref = repo ?? (isGithub(href) ? href : undefined)
const caseStudyHref = caseStudySlug
  ? (locale === 'es' ? `/es/projects/${caseStudySlug}` : `/projects/${caseStudySlug}`)
  : undefined
const primaryLabel =
  locale === 'es'
    ? isGithub(href)
      ? 'Código'
      : 'Ver'
    : isGithub(href)
      ? 'Code'
      : 'Live'
const codeLabel = locale === 'es' ? 'Código' : 'Code'
const caseStudyLabel = locale === 'es' ? 'Ver caso' : 'Case study'
---

<li
  class='project-card group/card relative overflow-hidden rounded-xl border border-border bg-background transition hover:bg-primary/5'
>
  <div
    class='pointer-events-none absolute inset-0 opacity-0 transition duration-300 group-hover/card:opacity-100'
    style='background: radial-gradient(600px circle at var(--x, 50%) var(--y, 50%), rgba(99,102,241,.12), transparent 40%);'
  />

  <div class='flex h-full flex-col'>
    <a
      href={liveHref}
      target='_blank'
      rel='noopener noreferrer'
      class='flex min-h-0 flex-1 flex-col text-inherit no-underline outline-none'
    >
      <div class='relative h-40 w-full overflow-hidden border-b border-border bg-muted sm:h-44'>
        {
          image ? (
            <img
              src={image}
              alt={`${title} preview`}
              class='h-full w-full object-cover object-center transition duration-300 group-hover/card:scale-[1.02]'
              loading='lazy'
            />
          ) : (
            <div class='grid h-full w-full place-items-center'>
              <div class='rounded-2xl border border-border bg-background/70 p-4 backdrop-blur'>
                <img src={icon} alt={`${title} icon`} class='size-10' />
              </div>
            </div>
          )
        }
      </div>

      <div class='flex flex-1 flex-col gap-3 p-4'>
        <header class='flex items-start justify-between gap-3'>
          <div class='flex min-w-0 flex-col gap-1'>
            <h2 class='truncate font-semibold'>{title}</h2>
            {meta ? <p class='text-xs text-secondary'>{meta}</p> : null}
          </div>
          <img
            class='mt-1 size-4 shrink-0 transition group-hover/card:translate-x-1'
            src='/svg/arrow-right.svg'
            alt=''
          />
        </header>

        <p class='text-sm text-secondary'>{description}</p>

        {
          tags?.length ? (
            <ul class='flex flex-wrap gap-2'>
              {tags.slice(0, 3).map((tag) => (
                <li class='rounded-full border border-border bg-background px-2 py-1 text-[11px] text-secondary'>
                  {tag}
                </li>
              ))}
            </ul>
          ) : null
        }

        <ul class='flex flex-wrap gap-1'>
          {
            stack.slice(0, 4).map((item) => (
              <li class='flex items-center gap-1 rounded-md border border-secondary/15 bg-muted px-2 py-1 text-xs'>
                <img src={item.icon} class='size-4' alt='' loading='lazy' />
                {item.name}
              </li>
            ))
          }
        </ul>
      </div>
    </a>

    <footer class='flex flex-wrap gap-2 px-4 pb-4 pt-0'>
      {caseStudyHref ? (
        <a
          class='inline-flex min-w-fit items-center justify-center gap-2 rounded-lg border border-border bg-background px-3 py-2 text-xs font-semibold transition hover:bg-muted'
          href={caseStudyHref}
        >
          {caseStudyLabel}
        </a>
      ) : null}
      <a
        class='inline-flex min-w-fit items-center justify-center gap-2 rounded-lg border border-border bg-background px-3 py-2 text-xs font-semibold transition hover:bg-muted'
        target='_blank'
        rel='noopener noreferrer'
        href={liveHref}
      >
        {primaryLabel}
      </a>

      {codeHref && !isGithub(href) ? (
        <a
          class='inline-flex min-w-fit items-center justify-center gap-2 rounded-lg border border-border bg-background px-3 py-2 text-xs font-semibold transition hover:bg-muted'
          target='_blank'
          rel='noopener noreferrer'
          href={codeHref}
        >
          {codeLabel}
        </a>
      ) : null}
    </footer>
  </div>
</li>

<script>
  document.addEventListener('astro:page-load', () => {
    const cards = document.querySelectorAll<HTMLElement>('.project-card')
    cards.forEach((card) => {
      card.addEventListener('pointermove', (e: PointerEvent) => {
        const rect = card.getBoundingClientRect()
        const x = ((e.clientX - rect.left) / rect.width) * 100
        const y = ((e.clientY - rect.top) / rect.height) * 100
        card.style.setProperty('--x', `${x}%`)
        card.style.setProperty('--y', `${y}%`)
      })
    })
  })
</script>
